# Backend environment variables
# Copy to .env and fill in your values

PORT=4000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=djapp
PGUSER=postgres
PGPASSWORD=your_password_here

# CORS – one or many origins separated by commas
# Example: https://app.midominio.com,https://admin.midominio.com
# Use * only if you explicitly want to allow any origin
CLIENT_ORIGIN=http://localhost:5173
