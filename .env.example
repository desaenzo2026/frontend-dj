# If frontend and backend share the same domain/reverse proxy,
# leave both values empty and the app will use /api and /socket.io.
# VITE_API_URL=
# VITE_SOCKET_URL=

# If deployed in different domains, set full backend URLs:
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
